# ==============================================================================
# Required at every stage
# ==============================================================================

# Database connection string.
#   Local dev  → native Postgres:  postgresql://<you>@localhost:5432/<app>_dev
#                (run `pnpm db:local` to create it and print this line)
#   Preview/prod → Neon:  postgresql://user:password@ep-xxx.aws.neon.tech/neondb?sslmode=require
# The db client (src/db/index.ts) auto-selects the driver from this URL.
DATABASE_URL="postgresql://postgres@localhost:5432/app_dev"

# better-auth signing secret — REQUIRED. Generate with:  openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Public base URL. localhost in dev; your real domain in prod.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Set to 1 to skip env validation (useful for CI builds without a DB).
# SKIP_ENV_VALIDATION=1

# ==============================================================================
# Auth — social login (optional; each provider is inert until its keys are set)
# See docs/setup/auth-setup.md for step-by-step provider setup.
# ==============================================================================

# Google — https://console.cloud.google.com/apis/credentials
#   Authorized redirect URI: <APP_URL>/api/auth/callback/google
NEXT_PUBLIC_GOOGLE_ENABLED="0"        # flip to "1" to show the Google button
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Apple — https://developer.apple.com (requires the $99/yr Apple Developer Program)
#   APPLE_CLIENT_SECRET is a JWT you generate from your key; it EXPIRES (≤6 months).
#   Redirect URI: <APP_URL>/api/auth/callback/apple
NEXT_PUBLIC_APPLE_ENABLED="0"         # flip to "1" to show the Apple button
APPLE_CLIENT_ID=""                    # your Services ID (e.g. com.example.app.web)
APPLE_CLIENT_SECRET=""                # generated client-secret JWT

# ==============================================================================
# Email (optional) — verification + password-reset delivery.
# Unset → links are logged to the server console (fine for local dev).
# Set   → sent via AWS SES. Credentials come from the AWS SDK's default
#         provider chain (IAM role, `aws configure` profile, etc.) — no
#         secret keys to set here. The sending identity (EMAIL_FROM) must be
#         a verified SES identity/domain in that region.
# ==============================================================================

AWS_REGION=""
EMAIL_FROM="noreply@yourdomain.com"

# ==============================================================================
# Billing — Stripe (optional; billing is inert until STRIPE_SECRET_KEY is set)
# See docs/setup/stripe.md. Local webhooks: `stripe listen --forward-to
# localhost:3000/api/webhooks/stripe` (copy the printed whsec_… below).
# ==============================================================================

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SIGNING_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_STRIPE_PRICE_ID=""        # the price the demo checkout button buys

# ==============================================================================
# AI features (optional) — flips on the AI Disclosure footer link and the
# <AiDisclosureNotice> component once this app has an AI-facing feature.
# See src/app/(legal)/ai-disclosure/page.tsx and docs/legal.md.
# ==============================================================================

NEXT_PUBLIC_AI_FEATURES_ENABLED="0"   # flip to "1" once you ship an AI feature
